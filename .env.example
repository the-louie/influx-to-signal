# InfluxDB settings
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=home_assistant

# Flux query filters
MEASUREMENT=http_listener_v2
FIELD=temperature
DEVICE_ID=gisebo-01
HOST_FILTER=61781446e5e9

# Timezone offset from UTC (used to determine "start of yesterday")
TZ_OFFSET_HOURS=2

# signal-cli-rest-api service settings
SIGNAL_API_MODE=json-rpc
SIGNAL_API_PORT=8080

# Signal message delivery
SIGNAL_PROTOCOL=http
SIGNAL_SERVICE=signal-api:8080
SIGNAL_PHONE_NUMBER=+46701234567
SIGNAL_RECIPIENT=group.YourGroupIdHere=

# Scheduling
CRON_SCHEDULE=0 10 * * *
RUN_ON_STARTUP=false

# Active period (optional, inclusive, format: YYYY-MM-DD)
# Messages are only sent when today falls within this window.
# Leave both empty to send year-round.
ACTIVE_FROM=2026-04-01
ACTIVE_TO=2026-09-30
