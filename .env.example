# InfluxDB settings
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=home_assistant

# Flux query filters
MEASUREMENT=http_listener_v2
FIELD=temperature
DEVICE_ID=gisebo-01
HOST_FILTER=61781446e5e9

# Timezone offset from UTC (used to determine "start of yesterday")
TZ_OFFSET_HOURS=2

# Signal settings (signal-cli-rest-api)
SIGNAL_PROTOCOL=http
SIGNAL_SERVICE=signal-api:8080
SIGNAL_PHONE_NUMBER=+46701234567
SIGNAL_RECIPIENT=group.YourGroupIdHere=
